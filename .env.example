# Supabase Connection
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Cloudflare R2 Connection
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_aws_access_key
R2_SECRET_ACCESS_KEY=your_aws_secret_key
R2_BUCKET_NAME=your_bucket_name
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-r2-public-domain.com

# Fiscalization — URL of the local fiscal-device bridge running on the cashier PC.
# Leave empty until the device is wired. Example: http://localhost:7000
NEXT_PUBLIC_FISCAL_BRIDGE_URL=
