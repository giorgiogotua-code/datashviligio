# Supabase Connection
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Cloudflare R2 Connection
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_aws_access_key
R2_SECRET_ACCESS_KEY=your_aws_secret_key
R2_BUCKET_NAME=your_bucket_name
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-r2-public-domain.com

# Fiscalization — Daisy eXpert via the ErpNet.FP local bridge (https://github.com/erpnet/ErpNet.FP)
# Install ErpNet.FP on the cashier PC; it auto-detects the Daisy on USB.
NEXT_PUBLIC_FISCAL_BRIDGE_URL=http://localhost:8001
# Optional: force a specific printer id (else the first detected device is used). See GET /printers
NEXT_PUBLIC_FISCAL_PRINTER_ID=
# Tax group programmed on the device for Georgian VAT (verify on the real device)
NEXT_PUBLIC_FISCAL_TAX_GROUP=1
# Optional: unique-sale-number prefix (leave empty to let the device auto-number)
NEXT_PUBLIC_FISCAL_USN_PREFIX=
